{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "functions": {
    "api/page.js": {
      "includeFiles": "dist/**"
    },
    "api/auth/*.js": {
      "includeFiles": "lib/**"
    },
    "api/admins/*.js": {
      "includeFiles": "lib/**"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/index.html",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/login",
      "destination": "/admin-login.html"
    }
  ]
}
