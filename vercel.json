{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "functions": {
    "api/page.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/page"
    },
    {
      "src": "^/index\\.html$",
      "status": 302,
      "headers": {
        "Location": "/"
      }
    },
    {
      "src": "^/admin/?$",
      "dest": "/api/page?file=admin"
    },
    {
      "src": "^/admin\\.html$",
      "dest": "/api/page?file=admin"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ]
}
